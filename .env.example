# Copy to .env.local and fill in before deploying.

# Public site URL (no trailing slash) — used for sitemap, OpenGraph, canonical URLs
# Production: https://decathemes.vercel.app
NEXT_PUBLIC_SITE_URL=https://decathemes.vercel.app

# CodeCanyon item URL or your checkout page — powers "Buy now" CTAs
NEXT_PUBLIC_PURCHASE_URL=https://codecanyon.net/item/your-item-slug

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
